{
  "name": "@r3e/neo-js",
  "version": "0.1.2",
  "description": "Neo N3 JavaScript SDK inspired by r3e-network/neo-python-sdk with expanded RPC coverage.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/r3e-network/neo-js-sdk.git"
  },
  "homepage": "https://github.com/r3e-network/neo-js-sdk#readme",
  "bugs": {
    "url": "https://github.com/r3e-network/neo-js-sdk/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "keywords": [
    "neo",
    "neo-n3",
    "sdk",
    "javascript",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "@cityofzion/neon-core": "^5.8.1",
    "bs58": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
