{
  "name": "@r3e/neo-js-sdk",
  "version": "0.3.7",
  "description": "Neo N3 JavaScript/TypeScript SDK — successor to neo-js (no longer maintained). Typed models, object-based RPC inputs, full N3 RPC coverage.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/r3e-network/neo-js-sdk.git"
  },
  "homepage": "https://github.com/r3e-network/neo-js-sdk#readme",
  "bugs": {
    "url": "https://github.com/r3e-network/neo-js-sdk/issues"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/browser.js",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    },
    "./core": {
      "types": "./dist/core-exports.d.ts",
      "default": "./dist/core-exports.js"
    },
    "./compat/browser": {
      "types": "./dist/compat/browser.d.ts",
      "default": "./dist/compat/browser.js"
    },
    "./compat/sc": {
      "types": "./dist/compat/sc.d.ts",
      "default": "./dist/compat/sc.js"
    },
    "./compat/tx": {
      "types": "./dist/compat/tx.d.ts",
      "default": "./dist/compat/tx.js"
    },
    "./compat/u": {
      "types": "./dist/compat/hex-string.d.ts",
      "default": "./dist/compat/hex-string.js"
    },
    "./compat/contract-param": {
      "types": "./dist/compat/contract-param.d.ts",
      "default": "./dist/compat/contract-param.js"
    },
    "./compat/wallet-helpers": {
      "types": "./dist/compat/wallet-helpers.d.ts",
      "default": "./dist/compat/wallet-helpers.js"
    },
    "./wallet/browser": {
      "types": "./dist/wallet/nep6-browser.d.ts",
      "default": "./dist/wallet/nep6-browser.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "coverage": "vitest run --coverage.enabled true --coverage.provider v8 --coverage.reporter=text --coverage.reporter=json-summary",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test:integration": "RUN_NEO_LIVE=1 vitest run tests/integration/rpc-live.test.ts",
    "test:integration:wif": "RUN_NEO_LIVE=1 vitest run tests/integration/rpc-live-wif.test.ts"
  },
  "keywords": [
    "neo",
    "neo-n3",
    "neo-js",
    "sdk",
    "javascript",
    "typescript",
    "blockchain",
    "n3"
  ],
  "license": "MIT",
  "dependencies": {
    "@noble/curves": "^1.9.0",
    "@noble/hashes": "^1.8.0",
    "bs58": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
